# Application
APP_ENV=development
LOG_LEVEL=INFO

# Output paths
OUTPUT_ROOT=./output
WORK_ROOT=./work
STARTER_REPO_CACHE_DIR=./work/starter-cache

# GitHub
GITHUB_TOKEN=ghp_your_token_here
STARTER_REPO_URL=https://github.com/<org>/<starter-repo>.git
STARTER_REPO_BRANCH=main

# Claude Code
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_TIMEOUT_SECONDS=300
CLAUDE_CODE_MAX_REPAIR_ATTEMPTS=2

# OpenAI (for ideation/ranking/CLAUDE.md generation/markdown)
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o

# Langfuse (optional observability)
ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# SQLite persistence
DATABASE_URL=sqlite+aiosqlite:///./poc_factory.db

# Defaults
DEFAULT_TARGET_POC_COUNT=10
MAX_CONCURRENT_POCS=3
